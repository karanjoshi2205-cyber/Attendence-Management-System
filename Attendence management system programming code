#include <stdio.h>
#include <stdlib.h>
#include <string.h>

struct Date
{
    int day;
    int month;
    int year;
};
struct Attendance
{
    int id;
    char name[50];
    struct Date d;
    char status[10];
};
void markAttendance()
{
    FILE *fp = fopen("attendance.txt", "a");

    struct Attendance a;
    int n, i;

    if (fp == NULL)
    {
        printf("Error opening file!\n");
        return;
    }

    printf("\nEnter number of students: ");
    scanf("%d", &n);

    for (i = 0; i < n; i++)
    {
        printf("\n--- Student %d ---\n", i + 1);

        printf("Enter ID: ");
        scanf("%d", &a.id);

        printf("Enter Name: ");
        scanf("%s", a.name);

        printf("Enter Date (DD MM YYYY): ");
        scanf("%d %d %d", &a.d.day, &a.d.month, &a.d.year);

        printf("Enter Status (Present/Absent): ");
        scanf("%s", a.status);

        if (strcmp(a.status, "Present") != 0 && strcmp(a.status, "Absent") != 0)
        {
            printf("Invalid status! Enter Present or Absent.\n");
            i--;
            continue;
        }

        fprintf(fp, "%d %s %d-%d-%d %s\n",
                a.id, a.name,
                a.d.day, a.d.month, a.d.year,
                a.status);
    }

    fclose(fp);

    printf("\nAttendance recorded successfully!\n");
}

void viewRecords()
{
    FILE *fp = fopen("attendance.txt", "r");

    int id, d, m, y;
    char name[50], status[10];

    if (fp == NULL)
    {
        printf("No records found!\n");
        return;
    }

    printf("\n--- Attendance Records ---\n");

    while (fscanf(fp, "%d %s %d-%d-%d %s",
                  &id, name, &d, &m, &y, status) != EOF)
    {

        printf("\nID: %d\nName: %s\nDate: %02d-%02d-%d\nStatus: %s\n",
               id, name, d, m, y, status);
    }

    fclose(fp);
}
void searchByID() {
    FILE *fp = fopen("attendance.txt", "r");

    int id, searchID, d, m, y, found = 0;
    char name[50], status[10];

    if (fp == NULL) {
        printf("No records found!\n");
        return;
    }

    printf("\nEnter ID to search: ");
    scanf("%d", &searchID);

    while (fscanf(fp, "%d %s %d-%d-%d %s",
                  &id, name, &d, &m, &y, status) != EOF) {

        if (id == searchID) {
            printf("\nRecord Found:\n");
            printf("ID: %d\nName: %s\nDate: %02d-%02d-%d\nStatus: %s\n",
                   id, name, d, m, y, status);
            found = 1;
        }
    }

    if (!found)
        printf("No record found!\n");

    fclose(fp);
}

void searchByDate() {
    FILE *fp = fopen("attendance.txt", "r");

    int id, d, m, y, sd, sm, sy, found = 0;
    char name[50], status[10];

    if (fp == NULL) {
        printf("No records found!\n");
        return;
    }

    printf("\nEnter Date (DD MM YYYY): ");
    scanf("%d %d %d", &sd, &sm, &sy);

    while (fscanf(fp, "%d %s %d-%d-%d %s",
                  &id, name, &d, &m, &y, status) != EOF) {

        if (d == sd && m == sm && y == sy) {
            printf("\nRecord Found:\n");
            printf("ID: %d\nName: %s\nStatus: %s\n",
                   id, name, status);
            found = 1;
        }
    }

    if (!found)
        printf("No records found!\n");

    fclose(fp);
}
void teacherPanel() {
    int pass, choice;

    printf("\n--- Teacher Login ---\n");
    printf("Enter Password: ");
    scanf("%d", &pass);

    if (pass != 1234) {
        printf("Wrong Password!\n");
        return;
    }

    printf("Login Successful!\n");

    do {
        printf("\n--- Teacher Menu ---\n");
        printf("1. Mark Attendance\n");
        printf("2. Back\n");
        printf("Enter choice: ");
        scanf("%d", &choice);

        switch (choice) {
            case 1:
                markAttendance();
                break;
            case 2:
                break;
            default:
                printf("Invalid choice!\n");
        }

    } while (choice != 2);
}
int main() {
    int choice;

    while (1) {
        printf("\n===== Attendance Management System =====\n");
        printf("1. Teacher Panel\n");
        printf("2. View Records\n");
        printf("3. Search by ID\n");
        printf("4. Search by Date\n");
        printf("5. Exit\n");

        printf("Enter your choice: ");
        scanf("%d", &choice);

        switch (choice) {
            case 1:
                teacherPanel();
                break;
            case 2:
                viewRecords();
                break;
            case 3:
                searchByID();
                break;
            case 4:
                searchByDate();
                break;
            case 5:
                printf("Exiting...\n");
                exit(0);
            default:
                printf("Invalid choice!\n");
        }
    }
    return 0;
}
